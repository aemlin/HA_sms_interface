# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# WiFi
WIFI_SSID=your_wifi_ssid
WIFI_PASSWORD=your_wifi_password

# MQTT Broker
MQTT_HOST=192.168.1.x
MQTT_PORT=1883
MQTT_USER=your_mqtt_user
MQTT_PASSWORD=your_mqtt_password
MQTT_CLIENT_ID=lilygo-sms-gateway

# MQTT Topics
MQTT_TOPIC_INCOMING=sms/incoming
MQTT_TOPIC_SEND=sms/send
MQTT_TOPIC_STATUS=sms/status

# SIM / Modem
SIM_APN=your_apn
SIM_PIN=         # leave empty if no PIN

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=60

# Default SMS recipient (used when sms/send MQTT payload has no "recipient" field)
DEFAULT_RECIPIENT=+32XXXXXXXXX

# OTA (Over-The-Air update)
OTA_PASSWORD=change_me_before_use
OTA_HOSTNAME=lilygo-sms-gateway
